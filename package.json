{
  "name": "typedenv",
  "version": "1.0.0",
  "description": "Type-safe environment variable validation for Node.js. Zero dependencies.",
  "author": "aradhyacp",
  "repository": {
    "type": "git",
    "url": "https://github.com/aradhyacp/typedenv.git"
  },
  "homepage": "https://github.com/aradhyacp/typedenv#readme",
  "bugs": {
    "url": "https://github.com/aradhyacp/typedenv/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "env",
    "environment",
    "environment-variables",
    "express",
    "validation",
    "validator",
    "typescript",
    "type-safe",
    "dotenv",
    "schema",
    "runtime-validation",
    "node",
    "nodejs",
    "config",
    "configuration",
    "startup",
    "zero-dependencies"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
